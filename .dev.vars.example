# Local Wrangler development variables.
# Copy to .dev.vars for local runs, fill values locally, and keep the file ignored.
# Secret values must not be committed or printed. Harden local copies with:
# chmod 0600 .dev.vars

SWITCHBOARD_API_KEY=
ADMIN_API_KEY=
NIM_HEALTH_TOKEN=

# Provider credentials and subscription account material.
ZAI_KEY_1=
NIM_KEY_1=
# Flat JSON object with access_token, refresh_token, and id_token.
CHATGPT_AUTH_JSON='{"access_token":"","refresh_token":"","id_token":""}'
ANTHROPIC_OAUTH_ACCOUNT=
ANTHROPIC_CLIENT_ID=
ANTHROPIC_CLIENT_SECRET=
