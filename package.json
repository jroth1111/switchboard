{
  "name": "worker-control-plane",
  "description": "Cloudflare Worker LLM control plane with NIM mitigation, account rotation, and silent failover",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config wrangler.dev.jsonc",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --config wrangler.dev.jsonc",
    "deploy:fixture": "wrangler deploy --config wrangler.provider-fixture.jsonc",
    "live:smoke": "node scripts/live-smoke.ts",
    "types:worker": "node scripts/worker-types.ts write",
    "types:worker:check": "node scripts/worker-types.ts check",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "tsc": "tsc --noEmit",
    "validate": "node scripts/check-secret-permissions.ts && node scripts/worker-types.ts check && node scripts/validate-manifest.ts",
    "snapshot": "node scripts/write-manifest-snapshot.ts",
    "bundle-size": "node scripts/bundle-size.ts",
    "failures": "node scripts/failures.ts"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.20",
    "@types/node": "^22.15.0",
    "@vitest/expect": "3.2.4",
    "@vitest/mocker": "3.2.4",
    "@vitest/pretty-format": "3.2.4",
    "@vitest/runner": "3.2.4",
    "@vitest/snapshot": "3.2.4",
    "@vitest/spy": "3.2.4",
    "@vitest/utils": "3.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.87.0",
    "yaml": "^2.7.0"
  },
  "dependencies": {
    "jsonrepair": "^3.14.0"
  }
}
