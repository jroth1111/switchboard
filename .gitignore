.dev.vars.*
!.dev.vars.example

.env
.env.*
!.env.example

.secrets/
**/.secrets/

# OAuth / API key JSON (not CI fixtures)
**/chatgpt-auth.json
!config/fixtures/chatgpt-auth.ci.json

config/client-keys.json
config/client-keys.*.json
!config/client-keys.example.json
!config/fixtures/client-keys.ci.json

# Wrangler / smoke / key material
.wrangler/
.live-smoke-report.json
*.pem
*.p12
*.pfx
*.key
!**/*.example.key

# Misc credential stores
.netrc
.beads-credential-key

